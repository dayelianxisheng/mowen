    <!-- Drive plugin -->
    <plugin name='mowen_drive' filename='libgazebo_ros_planar_move.so'>
      <ros>
        <remapping>~/cmd_vel:=cmd_vel</remapping>
        <remapping>~/odom:=odom</remapping>
      </ros>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_odom>true</publish_odom>
    </plugin>

    <!-- Joint state publisher -->
    <plugin name='mowen_joint_state' filename='libgazebo_ros_joint_state_publisher.so'>
      <ros>
        <remapping>~/out:=joint_states</remapping>
      </ros>
      <update_rate>50</update_rate>
      <joint_name>front_left_joint</joint_name>
      <joint_name>front_right_joint</joint_name>
      <joint_name>back_left_joint</joint_name>
      <joint_name>back_right_joint</joint_name>
    </plugin>
  </model>
